# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OpenRouteService API Key (Optional, simulated if missing)
ORS_API_KEY="eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6ImNiOTMzYmMwZWZlZDQ3NmJhZGVjMTc5NDY0NjUxZGRiIiwiaCI6Im11cm11cjY0In0="

# Routing engine selection: "ors" (default) or "otp" (OpenTripPlanner).
ROUTING_ENGINE="ors"

# OpenTripPlanner (OTP) settings (no Docker required).
# Run OTP locally (java) and point the app here.
OTP_BASE_URL="http://localhost:8080"
# OTP1 default REST plan endpoint:
OTP_PLAN_PATH="/otp/routers/default/plan"

# Air Quality (Optional): WAQI token for AQI exposure scoring.
# If missing, exposure scoring falls back to a simple heuristic.
WAQI_TOKEN=""

# Frontend map mode
# Set true to use MapLibre vector tiles in RouteMap (fallback map remains available).
VITE_USE_VECTOR_TILES="false"

VITE_MAP_STYLE_URL="https://demotiles.maplibre.org/style.json"

VITE_PMTILES_URL="http://localhost:3000"

VITE_API_BASE_URL="http://localhost:3000/api"
